#!/bin/sh
# overlay-init - In-guest OverlayFS setup for Firecracker VMs
#
# Based on firecracker-containerd's overlay-init:
# https://github.com/firecracker-microvm/firecracker-containerd
#
# Usage:
#   Kernel boot args: init=/sbin/overlay-init overlay_root=vdc
#   For layered images: init=/sbin/overlay-init overlay_root=vdd parent_layers=vdb,vdc
#   For Docker volume:  init=/sbin/overlay-init overlay_root=vdb docker_volume=vdc
#
# IMPORTANT: The rootfs MUST have /overlay and /mnt directories pre-created!
#
# Layer stacking (from bottom to top):
#   - Base rootfs (vda) - read-only kernel root
#   - Parent layers (vdb, vdc, ...) - read-only promoted snapshots
#   - Overlay device (vdN) - read-write layer for this VM
#   - Docker volume (vdN+1) - dedicated ext4 for /var/lib/docker (optional)
#
# Copyright Amazon.com, Inc. or its affiliates. All Rights Reserved.
# SPDX-License-Identifier: Apache-2.0

# Mount /proc first so we can read /proc/cmdline
/bin/mount -t proc proc /proc

# Ensure required directories exist
mkdir -p /overlay /mnt /rom

# Parse kernel command line for overlay_root, parent_layers, and docker_volume parameters
for arg in $(cat /proc/cmdline); do
    case "$arg" in
        overlay_root=*)
            overlay_root="${arg#overlay_root=}"
            ;;
        parent_layers=*)
            parent_layers="${arg#parent_layers=}"
            ;;
        docker_volume=*)
            docker_volume="${arg#docker_volume=}"
            ;;
    esac
done

# pivot_root to the overlay filesystem
pivot() {
    local rw_root work_dir lowerdir
    rw_root="$1"
    work_dir="$2"
    lowerdir="$3"

    /bin/mount \
        -o noatime,lowerdir=${lowerdir},upperdir=${rw_root},workdir=${work_dir} \
        -t overlay "overlayfs:${rw_root}" /mnt

    cd /mnt
    pivot_root . rom
}

# Mount parent layers and build lowerdir string
# Returns the lowerdir via the LOWERDIR global variable
mount_parent_layers() {
    LOWERDIR="/"

    if [ -z "$parent_layers" ]; then
        return
    fi

    # parent_layers is comma-separated: vdb,vdc,vdd
    # These are ordered from base to derived (vdb is closest to rootfs, vdc is more derived)
    # overlayfs lowerdir must be from TOP to BOTTOM (most derived first)

    # Convert comma-separated to space-separated and count layers
    layer_list=$(echo "$parent_layers" | tr ',' ' ')
    layer_count=0
    for layer in $layer_list; do
        layer_count=$((layer_count + 1))
    done

    # Create a tmpfs for parent layer mount points since rootfs is read-only
    # We use /run which is typically a tmpfs, or fall back to mounting our own
    PARENT_MOUNT_BASE="/run/parent-layers"
    if ! mkdir -p "$PARENT_MOUNT_BASE" 2>/dev/null; then
        # /run might not exist or be read-only, mount tmpfs at /tmp and use that
        /bin/mount -t tmpfs -o noatime,size=1M tmpfs /tmp 2>/dev/null || true
        PARENT_MOUNT_BASE="/tmp/parent-layers"
        mkdir -p "$PARENT_MOUNT_BASE"
    fi
    echo "[overlay-init] Using $PARENT_MOUNT_BASE for parent layer mounts"

    # Mount each parent layer in order (idx matches position in parent_layers)
    # /parent1 gets vdb (base-most), /parent2 gets vdc (more derived), etc.
    idx=1
    for layer in $layer_list; do
        mount_point="${PARENT_MOUNT_BASE}/parent${idx}"
        mkdir -p "$mount_point"
        if [ -b "/dev/${layer}" ]; then
            /bin/mount -t ext4 -o noatime,ro "/dev/${layer}" "$mount_point"
            echo "[overlay-init] Mounted parent layer /dev/${layer} at $mount_point"
        else
            echo "[overlay-init] WARNING: Parent layer /dev/${layer} not found"
        fi
        idx=$((idx + 1))
    done

    # Build lowerdir string from top (most derived) to bottom (base rootfs)
    # overlayfs lowerdir: first entry = top layer, last entry = bottom layer
    # /parentN/upper (most derived) -> /parent1/upper (base-most) -> / (rootfs)
    #
    # IMPORTANT: Parent layers are copied overlayfs upper directories, so files
    # are stored under /upper within each layer's ext4 filesystem!
    LOWERDIR=""
    for i in $(seq $layer_count -1 1); do
        mount_point="${PARENT_MOUNT_BASE}/parent${i}"
        if [ -d "$mount_point" ]; then
            # The layer ext4 has files under /upper (from the original overlay structure)
            layer_path="${mount_point}/upper"
            if [ -d "$layer_path" ]; then
                if [ -z "$LOWERDIR" ]; then
                    LOWERDIR="$layer_path"
                else
                    LOWERDIR="${LOWERDIR}:$layer_path"
                fi
            else
                echo "[overlay-init] WARNING: ${mount_point}/upper not found, using $mount_point"
                if [ -z "$LOWERDIR" ]; then
                    LOWERDIR="$mount_point"
                else
                    LOWERDIR="${LOWERDIR}:$mount_point"
                fi
            fi
        fi
    done
    # Append the base rootfs at the bottom
    LOWERDIR="${LOWERDIR}:/"

    echo "[overlay-init] Built lowerdir: ${LOWERDIR}"
}

# Set up the overlay filesystem
do_overlay() {
    # Mount parent layers first (if any)
    mount_parent_layers

    # Mount the overlay storage on /overlay (directory must pre-exist)
    if [ "$overlay_root" = "ram" ] || [ -z "$overlay_root" ]; then
        # Use tmpfs - changes are lost on reboot
        /bin/mount -t tmpfs -o noatime,mode=0755 tmpfs /overlay
    else
        # Use block device - changes persist
        /bin/mount -t ext4 -o noatime "/dev/$overlay_root" /overlay
    fi

    # Create overlayfs directories on the writable overlay storage
    mkdir -p /overlay/upper /overlay/work

    # Pivot to the overlay with the built lowerdir
    pivot /overlay/upper /overlay/work "$LOWERDIR"
}

# Validate block device if specified
if [ -n "$overlay_root" ] && [ "$overlay_root" != "ram" ]; then
    if [ ! -b "/dev/$overlay_root" ]; then
        echo "[overlay-init] FATAL: /dev/$overlay_root does not exist"
        exec /sbin/init "$@"
    fi
fi

# Set up overlay
do_overlay

# Set up agent user and SSH keys from overlay (runs before systemd)
# This ensures SSH access works even if mmds-configure fails
# After pivot_root, we're already at / in the new root (no cd needed)

# Debug: write to a log file we can check
exec 2>/overlay-init.log
set -x

echo "[overlay-init] Starting SSH setup"
echo "[overlay-init] PWD=$(pwd)"
echo "[overlay-init] ls /home/:"
ls -la /home/ 2>&1 || echo "No /home dir"
echo "[overlay-init] ls /home/agent/:"
ls -la /home/agent/ 2>&1 || echo "No /home/agent"
echo "[overlay-init] ls /home/agent/.ssh/:"
ls -la /home/agent/.ssh/ 2>&1 || echo "No .ssh dir"

# Check if we have pre-injected SSH keys in the overlay
if [ -d /home/agent/.ssh ] && [ -f /home/agent/.ssh/authorized_keys ]; then
    echo "[overlay-init] Found pre-injected SSH keys, setting up agent user..."

    # Agent user might not exist in base image - create it
    if ! grep -q "^agent:" /etc/passwd 2>/dev/null; then
        echo "[overlay-init] Creating agent user..."
        echo "agent:x:1000:1000:Agent User:/home/agent:/bin/bash" >> /etc/passwd
        echo "agent:x:1000:" >> /etc/group
        echo "agent:!:19000:0:99999:7:::" >> /etc/shadow
        mkdir -p /home/agent
    fi

    # Ensure correct permissions on SSH directory
    chown -R 1000:1000 /home/agent 2>/dev/null || true
    chown -R 1000:1000 /home/agent/.ssh 2>/dev/null || true
    chmod 700 /home/agent/.ssh 2>/dev/null || true
    chmod 600 /home/agent/.ssh/authorized_keys 2>/dev/null || true

    # Set up sudoers for agent
    mkdir -p /etc/sudoers.d
    if [ ! -f /etc/sudoers.d/agent ]; then
        echo "agent ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/agent
        chmod 440 /etc/sudoers.d/agent
    fi

    echo "[overlay-init] Agent user setup complete"
else
    echo "[overlay-init] No SSH keys found at /home/agent/.ssh/authorized_keys"
fi

# Mount dedicated Docker volume if specified
# This gives Docker its own ext4 filesystem, avoiding nested overlayfs issues.
# Docker overlay2 can then operate directly on ext4 instead of on the guest's overlayfs root.
if [ -n "$docker_volume" ] && [ -b "/dev/${docker_volume}" ]; then
    echo "[overlay-init] Mounting Docker volume /dev/${docker_volume} at /var/lib/docker"
    mkdir -p /var/lib/docker
    /bin/mount -t ext4 -o noatime "/dev/${docker_volume}" /var/lib/docker

    # Also put containerd's data on the ext4 volume.
    # containerd uses overlayfs snapshotter at /var/lib/containerd, which fails
    # if /var/lib/containerd is on the guest's overlayfs root (overlay-on-overlay).
    mkdir -p /var/lib/docker/containerd /var/lib/containerd
    /bin/mount --bind /var/lib/docker/containerd /var/lib/containerd
    echo "[overlay-init] Bind-mounted /var/lib/containerd on Docker volume"

    # Write Docker daemon config for overlay2 (dedicated volume supports it natively)
    # This overrides the default vfs config that exists as a fallback in the image
    mkdir -p /etc/docker
    echo '{"storage-driver":"overlay2"}' > /etc/docker/daemon.json
    echo "[overlay-init] Docker configured for overlay2 on dedicated volume"
elif [ -n "$docker_volume" ]; then
    echo "[overlay-init] WARNING: Docker volume /dev/${docker_volume} not found"
fi

# Now exec real init (we're already in the new root after pivot_root)
exec /sbin/init "$@"
