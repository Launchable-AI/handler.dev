# Handler Image Upload Configuration
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# These are used by upload-fc-image.sh and other dev scripts.

# AWS profile to use (from ~/.aws/config)
AWS_PROFILE=handler-admin

# S3 bucket for image storage (public read access)
S3_BUCKET=handler.dev-public

# S3 region
S3_REGION=us-east-2

# CloudFront distribution ID (optional, for cache invalidation after upload)
# Leave empty to skip invalidation
CLOUDFRONT_DISTRIBUTION_ID=
