{
  "name": "handler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "A web application for spawning and managing isolated compute sandboxes",
  "repository": {
    "type": "git",
    "url": "https://github.com/Launchable-AI/handler.dev.git"
  },
  "author": "Launchable.ai",
  "homepage": "https://github.com/Launchable-AI/handler.dev",
  "scripts": {
    "dev": "pnpm run dev:server & sleep 2 && pnpm run dev:web",
    "dev:server": "pnpm --filter server run dev",
    "dev:web": "pnpm --filter web run dev --host 0.0.0.0",
    "build": "pnpm --parallel run build",
    "lint": "pnpm --parallel run lint"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser": ">=5.3.6"
    }
  }
}
